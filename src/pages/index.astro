---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { actions } from 'astro:actions';
import Layout from '../layouts/Layout.astro';

const result = Astro.getActionResult(actions.contact);
---


<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="brands-section">
		<h2>Curated Brands</h2>

		<div class="logos-section">
			<img src="/cherokee-logo-change.webp" width="250" height="250" alt="" loading="eager" />
			<img src="/Logo_WLML.png" width="250" height="250" alt="" loading="eager" />
			<img src="/DJ-logo.png" width="250" height="250" alt="" loading="eager" />
			<img src="/ziera-logo.webp" width="250" height="250" alt="" loading="eager" />
		</div>
	</section>
	<section class="form-section">
		{result?.data?.success && (
			<p class="form-success">Thanks! We'll be in touch soon.</p>
		)}
		{result?.error && (
			<p class="form-error">Something went wrong. Please try again.</p>
		)}
		<form class="contact-form" method="POST" action={actions.contact}>
			<label for="name">
				<span class="sr-only">Name</span>
				<input type="text" name="name" id="name" placeholder="Name">
			</label>
			<label for="email">
				<span class="sr-only">Email</span>
				<input type="email" name="email" id="email" placeholder="Email">
			</label>
			<label for="phone">
				<span class="sr-only">Phone</span>
				<input type="tel" name="phone" id="phone" placeholder="Phone">
			</label>
			<button type="submit">Send</button>
		</form>
	</section>

	<section class="powered-section">
		<h3>Powered by</h3>
		
		<a href="https://ropstdigitall.com/" aria-label="Rop ST Digitall" target="_blank" rel="noopener noreferrer">
			<img src="/ROPst-logo.png" width="100" height="100" alt="" loading="lazy" />
		</a>
		
	</section>
</Layout>

<style>
	.brands-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		row-gap: 1em;

		h2 {
			text-transform: uppercase;
		}
	}
	
	.form-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		max-width: 580px;
		width: 100%;
		gap: 1em;
		padding: 2.5em 2em;
		border-radius: 12px;
		border: 3px solid rgba(255, 255, 255, 0.1);
		background: rgba(13, 15, 20, 0.6);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
	}

	.form-success {
		width: 100%;
		padding: 0.75em 1em;
		background: rgba(100, 220, 140, 0.12);
		border: 1px solid rgba(100, 220, 140, 0.4);
		border-radius: 8px;
		color: #6ddc8c;
		font-size: 0.9rem;
		margin: 0;
	}

	.form-error {
		width: 100%;
		padding: 0.75em 1em;
		background: rgba(255, 100, 100, 0.12);
		border: 1px solid rgba(255, 100, 100, 0.4);
		border-radius: 8px;
		color: #ff7070;
		font-size: 0.9rem;
		margin: 0;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		align-items: center;
		row-gap: 1em;
		width: 100%;

		label { 
			width: 100%;
		}
	}

	.logos-section {
		display: flex;
		align-items: center;
		justify-content: center;
		column-gap: 2em;
	}

	.powered-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		row-gap: 1em;

		h3 {
			text-transform: uppercase;
		}
	}
</style>