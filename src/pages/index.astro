---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { actions } from 'astro:actions';
import Layout from '../layouts/Layout.astro';

const result = Astro.getActionResult(actions.contact);

if (result?.data?.success) {
  return Astro.redirect('/?sent=1');
}

const sent   = Astro.url.searchParams.get('sent');
const failed = result?.error;
---


<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="brands-section">
		<h2>Distribution, Redefined.</h2>

		<p>We aren’t just moving boxes; we are architects of brand prestige. <span class="highlighted">The Curation Channel</span> is a premier distribution showroom dedicated to representing footwear brands in their most elevated form.  At retail and online.</p>

		<div class="logos-section">
			<a href="https://www.cherokeeofcalifornia.com/" target="_blank" rel="noopener noreferrer">
				<img src="/cherokee-logo-change.webp" width="100%" height="100%" alt="Cherokee of California" loading="eager" />
				<span class="sr-only">opens in a new tab</span>
			</a>
			<a href="https://www.woolloomoolooshoe.com/" target="_blank" rel="noopener noreferrer">
				<img src="/Logo_WLML.png" width="100%" height="100%" alt="Woolloomooloo" loading="eager" />
				<span class="sr-only">opens in a new tab</span>
			</a>
			<a href="https://djangoandjuliette.us/" target="_blank" rel="noopener noreferrer">
				<img src="/DJ-logo.png" width="100%" height="100%" alt="Django & Juliette" loading="eager" />
				<span class="sr-only">opens in a new tab</span>
			</a>
			<a href="https://zierashoes.us/" target="_blank" rel="noopener noreferrer">
				<img src="/ziera-logo.webp" width="100%" height="100%" alt="Ziera Shoes" loading="eager" />
				<span class="sr-only">opens in a new tab</span>
			</a>
		</div>
	</section>
	<section class="form-section">
		{sent && (
			<p class="form-success">Thanks! We'll be in touch soon.</p>
		)}
		{failed && (
			<p class="form-error">Something went wrong. Please try again.</p>
		)}
		<form class="contact-form" method="POST" action={actions.contact} aria-labelledby="form-heading" enctype="multipart/form-data">
			<p id="form-heading">Interested in membership?</p>
			<div class="honeypot" aria-hidden="true">
				<input type="text" name="website" id="website" tabindex="-1" autocomplete="off" />
			</div>
			<label for="name">
				<span class="sr-only">Name</span>
				<input type="text" name="name" id="name" placeholder="Name">
			</label>
			<label for="email">
				<span class="sr-only">Email</span>
				<input type="email" name="email" id="email" placeholder="Email">
			</label>
			<label for="phone" class="sr-only">Phone number</label>
			<input type="tel" id="phone" placeholder="Phone number" autocomplete="tel">
			<input type="hidden" name="phone" id="phone-full">
			<button type="submit">Send</button>
		</form>
	</section>

	<section class="powered-section">
		<h3>Powered by</h3>
		
		<a href="https://ropstdigitall.com/" target="_blank" rel="noopener noreferrer">
			<img src="/ROPst-logo.png" width="100" height="100" alt="Rop ST Digitall" loading="lazy" />
			<span class="sr-only">opens in a new tab</span>
		</a>
		
	</section>
</Layout>

<style>
	.brands-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		row-gap: 1em;

		h2 {
			font-size: clamp(18px, 3vw, 25px);
			text-align: center;
			text-transform: uppercase;
			
		}

		p {
			font-size: clamp(14px, 1vw, 16px);
		}

		.highlighted {
			color: var(--accent-dark);
		}
	}
	
	.form-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		max-width: 580px;
		width: 100%;
		gap: 1em;
		padding: 1.5em .4em;
		border-radius: 12px;
		border: 3px solid rgba(255, 255, 255, 0.1);
		background: rgba(13, 15, 20, 0.6);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);

		@media screen and (width >= 890px) {
			padding: 2.5em 2em;
		}
	}

	.form-success {
		width: 100%;
		padding: 0.75em 1em;
		background: rgba(100, 220, 140, 0.12);
		border: 1px solid rgba(100, 220, 140, 0.4);
		border-radius: 8px;
		color: #6ddc8c;
		font-size: 0.9rem;
		margin: 0;
	}

	.form-error {
		width: 100%;
		padding: 0.75em 1em;
		background: rgba(255, 100, 100, 0.12);
		border: 1px solid rgba(255, 100, 100, 0.4);
		border-radius: 8px;
		color: #ff7070;
		font-size: 0.9rem;
		margin: 0;
	}

	.honeypot {
		position: absolute;
		left: -9999px;
		visibility: hidden;
	}

	.iti {
		width: 100%;
	}

	.iti__tel-input {
		width: 100% !important;
	}

	.iti__flag-container .iti__selected-dial-code {
		color: rgba(255, 255, 255, 0.85);
		font-size: 0.875rem;
	}

	.iti__country-list {
		background-color: #1a1d26 !important;
		border: 1px solid rgba(255, 255, 255, 0.12) !important;
		color: #fff !important;
		border-radius: 8px;
		box-shadow: 0 8px 24px rgba(0,0,0,0.5);
	}

	.iti__country.iti__highlight,
	.iti__country:hover {
		background-color: rgba(255, 255, 255, 0.08) !important;
	}

	.iti__dial-code {
		color: rgba(255, 255, 255, 0.5) !important;
	}

	.iti__search-input {
		background-color: rgba(255, 255, 255, 0.05) !important;
		color: #fff !important;
		border-color: rgba(255, 255, 255, 0.15) !important;
		border-radius: 6px;
	}

	.iti__selected-country {
		background: transparent;
		border-radius: 8px 0 0 8px;
	}

	.iti__selected-country-primary:hover,
	.iti__selected-country-primary:focus {
		background-color: rgba(255, 255, 255, 0.06) !important;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		text-align: center;
		row-gap: 1em;
		width: 100%;

		label { 
			width: 100%;
		}
	}

	.logos-section {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		align-items: center;
		justify-items: center;
		gap: 2em;

		@media screen and (width >= 890px) {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	.powered-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		row-gap: 1em;

		h3 {
			font-size: clamp(14px, 2vw, 20px);
			text-transform: uppercase;
		}
	}
</style>

<script>
  import intlTelInput from 'intl-tel-input';
  import 'intl-tel-input/dist/css/intlTelInput.css';

  const success = document.querySelector('.form-success');
  const form = document.querySelector('.contact-form') as HTMLFormElement | null;
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const phoneInput = document.querySelector('#phone') as HTMLInputElement | null;
  const phoneFull = document.querySelector('#phone-full') as HTMLInputElement | null;

  if (success) {
    setTimeout(() => success.remove(), 5000);
  }

  let iti: ReturnType<typeof intlTelInput> | null = null;

  if (phoneInput) {
    iti = intlTelInput(phoneInput, {
      initialCountry: 'us',
      countrySearch: true,
      separateDialCode: true,
      loadUtils: () => import('intl-tel-input/utils'),
    });
  }

  form?.addEventListener('submit', (e) => {
    if (iti && phoneFull) {
      const fullNumber = iti.getNumber();
      if (fullNumber) phoneFull.value = fullNumber;
    }
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Sending...';
    }
  });
</script>