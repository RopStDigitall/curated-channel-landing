---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { actions } from 'astro:actions';
import Layout from '../layouts/Layout.astro';

const result = Astro.getActionResult(actions.contact);
---


<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="brands-section">
		<h2>Distribution, Redefined.</h2>

		<p>We aren’t just moving boxes; we are architects of brand prestige. <span class="highlighted">The Curation Channel</span> is a premier distribution showroom dedicated to representing footwear brands in their most elevated form.  At retail and online.</p>

		<div class="logos-section">
			<img src="/cherokee-logo-change.webp" width="100%" height="100%" alt="" loading="eager" />
			<img src="/Logo_WLML.png" width="100%" height="100%" alt="" loading="eager" />
			<img src="/DJ-logo.png" width="100%" height="100%" alt="" loading="eager" />
			<img src="/ziera-logo.webp" width="100%" height="100%" alt="" loading="eager" />
		</div>
	</section>
	<section class="form-section">
		{result?.data?.success && (
			<p class="form-success">Thanks! We'll be in touch soon.</p>
		)}
		{result?.error && (
			<p class="form-error">Something went wrong. Please try again.</p>
		)}
		<form class="contact-form" method="POST" action={actions.contact}>
			<label for="website" class="honeypot" aria-hidden="true">
				<input type="text" name="website" id="website" tabindex="-1" autocomplete="off" />
			</label>
			<label for="name">
				<span class="sr-only">Name</span>
				<input type="text" name="name" id="name" placeholder="Name">
			</label>
			<label for="email">
				<span class="sr-only">Email</span>
				<input type="email" name="email" id="email" placeholder="Email">
			</label>
			<label for="phone">
				<span class="sr-only">Phone</span>
				<input type="tel" name="phone" id="phone" placeholder="Phone">
			</label>
			<button type="submit">Send</button>
		</form>
	</section>

	<section class="powered-section">
		<h3>Powered by</h3>
		
		<a href="https://ropstdigitall.com/" aria-label="Rop ST Digitall" target="_blank" rel="noopener noreferrer">
			<img src="/ROPst-logo.png" width="100" height="100" alt="" loading="lazy" />
		</a>
		
	</section>
</Layout>

<style>
	.brands-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		row-gap: 1em;

		h2 {
			font-size: clamp(25px, 5vw, 40px);
			text-align: center;
			text-transform: uppercase;
			
		}

		p {
			font-size: clamp(16px, 2vw, 20px);
		}

		.highlighted {
			color: var(--accent-dark);
		}
	}
	
	.form-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		max-width: 580px;
		width: 100%;
		gap: 1em;
		padding: 1.5em .4em;
		border-radius: 12px;
		border: 3px solid rgba(255, 255, 255, 0.1);
		background: rgba(13, 15, 20, 0.6);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);

		@media screen and (width >= 890px) {
			padding: 2.5em 2em;
		}
	}

	.form-success {
		width: 100%;
		padding: 0.75em 1em;
		background: rgba(100, 220, 140, 0.12);
		border: 1px solid rgba(100, 220, 140, 0.4);
		border-radius: 8px;
		color: #6ddc8c;
		font-size: 0.9rem;
		margin: 0;
	}

	.form-error {
		width: 100%;
		padding: 0.75em 1em;
		background: rgba(255, 100, 100, 0.12);
		border: 1px solid rgba(255, 100, 100, 0.4);
		border-radius: 8px;
		color: #ff7070;
		font-size: 0.9rem;
		margin: 0;
	}

	.honeypot {
		position: absolute;
		left: -9999px;
		visibility: hidden;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		align-items: center;
		row-gap: 1em;
		width: 100%;

		label { 
			width: 100%;
		}
	}

	.logos-section {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		align-items: center;
		justify-items: center;
		gap: 2em;

		@media screen and (width >= 890px) {
			grid-template-columns: repeat(4, 1fr);
		}
	}

	.powered-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		row-gap: 1em;

		h3 {
			text-transform: uppercase;
		}
	}
</style>

<script>
  const success = document.querySelector('.form-success');
  const form = document.querySelector('.contact-form') as HTMLFormElement | null;
  const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  if (success) {
    setTimeout(() => success.remove(), 5000);
  }

  form?.addEventListener('submit', () => {
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Sending...';
    }
  });
</script>